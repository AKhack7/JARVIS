}

// ============================================================================
// MATH SOLVER (Basic)
// ============================================================================

bool isOperator(char c) {
    return c == '+' || c == '-' || c == '*' || c == '/';
}

int precedence(char op) {
    if (op == '+' || op == '-') return 1;
    if (op == '*' || op == '/') return 2;
    return 0;
}

double applyOp(double a, double b, char op) {
    switch(op) {
        case '+': return a + b;
        case '-': return a - b;
        case '*': return a * b;
        case '/': return a / b;
        default: return 0;
    }
}

double evaluateExpression(const std::string& expression) {
    std::vector<double> values;
    std::vector<char> ops;
    
    for (size_t i = 0; i < expression.length(); i++) {
        if (expression[i] == ' ') continue;
        
        if (isdigit(expression[i])) {
            double val = 0;
            while (i < expression.length() && isdigit(expression[i])) {
                val = (val * 10) + (expression[i] - '0');
                i++;
            }
            values.push_back(val);
            i--;
        }
        else if (expression[i] == '(') {
            ops.push_back(expression[i]);
        }
        else if (expression[i] == ')') {
            while (!ops.empty() && ops.back() != '(') {
                double val2 = values.back(); values.pop_back();
                double val1 = values.back(); values.pop_back();
                char op = ops.back(); ops.pop_back();
                values.push_back(applyOp(val1, val2, op));
            }
            if (!ops.empty()) ops.pop_back();
        }
        else if (isOperator(expression[i])) {
            while (!ops.empty() && precedence(ops.back()) >= precedence(expression[i])) {
                double val2 = values.back(); values.pop_back();
                double val1 = values.back(); values.pop_back();
                char op = ops.back(); ops.pop_back();
                values.push_back(applyOp(val1, val2, op));
            }
            ops.push_back(expression[i]);
        }
    }
    
    while (!ops.empty()) {
        double val2 = values.back(); values.pop_back();
        double val1 = values.back(); values.pop_back();
        char op = ops.back(); ops.pop_back();
        values.push_back(applyOp(val1, val2, op));
    }
    
    return values.back();
}

std::string solveMath(const std::string& expr) {
    try {
        std::string clean = std::regex_replace(expr, std::regex("×"), "*");
        clean = std::regex_replace(clean, std::regex("÷"), "/");
        clean = std::regex_replace(clean, std::regex("[^0-9+\\-*/()]"), "");
        
        double result = evaluateExpression(clean);
        std::stringstream ss;
        ss << "Answer: " << result << " 🧮";
        return ss.str();
    } catch (...) {
        return "Math solve nahi ho paya.";
    }
}

