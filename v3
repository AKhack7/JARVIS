// ============================================================================
// COMMAND PROCESSOR
// ============================================================================

std::string processCommand(const std::string& raw) {
    std::string cmd = toLower(trim(raw));
    
    if (cmd.empty()) return "";
    
    // Memory commands
    if (cmd.find("remember ") == 0) {
        std::string rest = cmd.substr(9);
        size_t isPos = rest.find(" is ");
        if (isPos != std::string::npos) {
            std::string key = rest.substr(0, isPos);
            std::string value = rest.substr(isPos + 4);
            memory.remember(key, value);
            return "Yaad rakh liya: " + key + " = " + value;
        }
        return "Format: remember [key] is [value]";
    }
    
    if (cmd.find("recall ") == 0 || cmd.find("what is ") == 0) {
        std::string key = cmd.substr(cmd.find_last_of(' ') + 1);
        std::string val = memory.recall(key);
        if (!val.empty()) {
            return key + " = " + val;
        }
        return "Mujhe '" + key + "' yaad nahi.";
    }
    
    // Date/Time
    if (stringContains(cmd, "time") || stringContains(cmd, "baja")) {
        return "Abhi " + getCurrentTime() + " baj rahe hain.";
    }
    
    if (stringContains(cmd, "date")) {
        return "Aaj " + getCurrentDate() + " hai.";
    }
    
    if (stringContains(cmd, "day") || stringContains(cmd, "din")) {
        return "Aaj " + getCurrentDay() + " hai.";
    }
    
    // Greetings
    for (const auto& pair : REPLIES) {
        if (stringContains(cmd, pair.first)) {
            std::random_device rd;
            std::mt19937 gen(rd());
            std::uniform_int_distribution<> dis(0, pair.second.size() - 1);
            return pair.second[dis(gen)];
        }
    }
    
    // Math
    if (stringContains(cmd, "+") || stringContains(cmd, "-") || 
        stringContains(cmd, "*") || stringContains(cmd, "/")) {
        return solveMath(cmd);
    }
    
    // Screenshot
    if (stringContains(cmd, "screenshot")) {
        takeScreenshot();
        return "Screenshot le liya! 📸";
    }
    
    // Volume controls
    if (stringContains(cmd, "volume up") || stringContains(cmd, "volume badha")) {
        controlVolume("up");
        return "Volume badha diya 🔊";
    }
    
    if (stringContains(cmd, "volume down") || stringContains(cmd, "volume kam")) {
        controlVolume("down");
        return "Volume kam kar diya 🔉";
    }
    
    if (stringContains(cmd, "mute")) {
        controlVolume("mute");
        return "Mute kar diya 🔇";
    }
    
    // Open apps
    if (stringContains(cmd, "open ") || stringContains(cmd, "kholo")) {
        for (const auto& app : APPS) {
            if (stringContains(cmd, app.first)) {
                openApp(app.first);
                return "'" + app.first + "' open kar raha hu 🚀";
            }
        }
        
        for (const auto& site : WEBSITES) {
            if (stringContains(cmd, site.first)) {
                openWebsite(site.first);
                return site.first + " open kar raha hu 🌐";
            }
        }
    }
    
    // Open settings
    if (stringContains(cmd, "setting")) {
        for (const auto& setting : SETTINGS) {
            if (stringContains(cmd, setting.first)) {
                openSetting(setting.first);
                return "'" + setting.first + "' settings open kar raha hu ⚙️";
            }
        }
    }
    
    // Alarm
    if (stringContains(cmd, "alarm")) {
        std::regex timeRegex(R"((\d{1,2}:\d{2}))");
        std::smatch match;
        if (std::regex_search(cmd, match, timeRegex)) {
            setAlarm(match[1]);
            return "Alarm set ho gaya " + match[1].str() + " ke liye ⏰";
        }
        return "Alarm time batao, jaise: alarm 07:30";
    }
    
    // Reminder
    if (stringContains(cmd, "remind") || stringContains(cmd, "yaad dilao")) {
        std::regex secondsRegex(R"((\d+)\s*second)");
        std::smatch match;
        if (std::regex_search(cmd, match, secondsRegex)) {
            int seconds = std::stoi(match[1]);
            std::string message = "Reminder!";
            setReminder(seconds, message);
            return "Reminder set ho gaya " + match[1].str() + " seconds baad 🔔";
        }
        return "Format: 30 second baad yaad dilao [message]";
    }
    
    // IP Address
    if (stringContains(cmd, "ip")) {
        return "Aapka IP address hai: " + getIPAddress() + " 🌐";
    }
    
    // Unknown
    std::vector<std::string> defaults = {
        "Samajh nahi aaya. Thoda aur clearly batao?",
        "Hmm, ye mujhe pata nahi. Google search karein?",
        "Iska jawab mujhe nahi pata abhi."
    };
    
    std::random_device rd;
    std::mt19937 gen(rd());
    std::uniform_int_distribution<> dis(0, defaults.size() - 1);
    return defaults[dis(gen)];
}

