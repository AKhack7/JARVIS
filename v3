        g_signal_connect(entry, "activate", G_CALLBACK(on_entry_activate), this);
        
        button = gtk_button_new_with_label("Send");
        gtk_box_pack_start(GTK_BOX(hbox), button, FALSE, FALSE, 0);
        g_signal_connect(button, "clicked", G_CALLBACK(on_send_clicked), this);
        
        micButton = gtk_button_new_with_label("🎤");
        gtk_box_pack_start(GTK_BOX(hbox), micButton, FALSE, FALSE, 0);
        g_signal_connect(micButton, "clicked", G_CALLBACK(on_mic_clicked), this);
        
        gtk_widget_show_all(window);
    }
    
    void run() {
        gtk_main();
    }
};

