    # ── Response display ─────────────────────────────────────────

    def show_response(self, text: str):
        """Show floating response tooltip near the capsule."""
        def _show():
            # Remove existing tooltip
            if hasattr(self, "_tooltip") and self._tooltip:
                try: self._tooltip.destroy()
                except: pass
            if self.response_after:
                self.root.after_cancel(self.response_after)

            tip = tk.Toplevel(self.root)
            tip.overrideredirect(True)
            tip.attributes("-topmost", True)
            tip.configure(bg=self.POPUP_BG)

            # Position above capsule
            rx = self.root.winfo_x()
            ry = self.root.winfo_y()

            lbl = tk.Label(
                tip, text=text,
                font=("Segoe UI", 10),
                fg=self.TEXT_MAIN, bg=self.POPUP_BG,
                wraplength=480, justify="left",
                padx=16, pady=10
            )
            lbl.pack()
            tip.update_idletasks()
            tw = tip.winfo_width()
            th = tip.winfo_height()
            tip.geometry(f"+{rx + (560-tw)//2}+{ry - th - 8}")

            # Rounded via highlight
            tip.configure(highlightbackground=self.CAPSULE_BD,
                          highlightthickness=1)
            self._tooltip = tip
            self.response_after = self.root.after(6000, self._hide_tooltip)

        self.root.after(0, _show)

    def _hide_tooltip(self):
        if hasattr(self, "_tooltip") and self._tooltip:
            try: self._tooltip.destroy()
            except: pass
            self._tooltip = None

    # ── Mic ─────────────────────────────────────────────────────

    def _toggle_mic(self, e=None):
        if not self.mic_on:
            self._start_mic()
        else:
            self._stop_mic()

    def _start_mic(self):
        self.mic_on = True
        self.canvas.itemconfig(self.mic_oval, fill=self.MIC_ON)
        self.canvas.itemconfig(self.mic_icon, text="🔴")
        self.show_response("Listening... 🎤")
        self.mic_thread = threading.Thread(target=self._listen_loop, daemon=True)
        self.mic_thread.start()

    def _stop_mic(self):
        self.mic_on = False
        self.canvas.itemconfig(self.mic_oval, fill=self.MIC_OFF)
        self.canvas.itemconfig(self.mic_icon, text="🎤")

    def _listen_loop(self):
        while self.mic_on:
            text = listen_once()
            if text:
                self.show_response(f"You: {text}")
                self._handle_command(text)
            else:
                if self.mic_on:
                    continue

    def _handle_command(self, cmd: str):
        response = process_command(cmd)
        if response:
            speak(response)

