class APIHandler:
    """Handles all API calls with proper error handling"""
    
    @staticmethod
    def get_weather(city: str) -> str:
        """Get weather information for a city"""
        config = API_CONFIG["weather"]
        if not config["enabled"] or not config["key"]:
            return "Weather API not configured. Please add API key in settings."
        
        try:
            params = {
                "q": city,
                "appid": config["key"],
                "units": "metric"
            }
            response = requests.get(config["url"], params=params, timeout=5)
            data = response.json()
            
            if response.status_code == 200:
                temp = data["main"]["temp"]
                feels_like = data["main"]["feels_like"]
                humidity = data["main"]["humidity"]
                description = data["weather"][0]["description"]
                city_name = data["name"]
                
                return f"{city_name} mein {temp}°C temperature hai, feels like {feels_like}°C. {description.capitalize()}. Humidity {humidity}% hai. 🌤️"
            else:
                return f"Weather info nahi mili. City name sahi hai? {data.get('message', '')}"
        except Exception as e:
            log.error(f"Weather API error: {e}")
            return "Weather check nahi ho paya. Internet check karo."
    
    @staticmethod
    def get_news(category: str = "general") -> str:
        """Get top news headlines"""
        config = API_CONFIG["news"]
        if not config["enabled"] or not config["key"]:
            return "News API not configured. Please add API key in settings."
        
        try:
            params = {
                "apiKey": config["key"],
                "category": category,
                "country": "in",
                "pageSize": 5
            }
            response = requests.get(config["url"], params=params, timeout=5)
            data = response.json()
            
            if response.status_code == 200 and data.get("articles"):
                articles = data["articles"][:3]
                news_list = []
                for i, article in enumerate(articles, 1):
                    title = article["title"]
                    source = article["source"]["name"]
                    news_list.append(f"{i}. {title} ({source})")
                
                return "Top news headlines:\n" + "\n".join(news_list) + "\n\n📰 Full details? search karo specific news."
            else:
                return "News nahi mili. Try again later."
        except Exception as e:
            log.error(f"News API error: {e}")
            return "News fetch nahi ho paya."
    
    @staticmethod
    def get_joke() -> str:
        """Get a random joke"""
        config = API_CONFIG["joke"]
        try:
            response = requests.get(config["url"], params={"type": "twopart"}, timeout=5)
            data = response.json()
            
            if data.get("type") == "twopart":
                setup = data.get("setup", "")
                delivery = data.get("delivery", "")
                return f"{setup}\n{delivery}"
            elif data.get("type") == "single":
                return data.get("joke", "")
            else:
                return "Joke nahi mila 😅"
        except Exception as e:
            log.error(f"Joke API error: {e}")
            return random.choice(["Mujhe koi joke yaad nahi aaya!", "Aap hi koi suna do!", "Joke time! Kya aapko pata hai main kya hu? Aapki assistant! 😄"])
    
    @staticmethod
    def get_quote() -> str:
        """Get an inspirational quote"""
        config = API_CONFIG["quote"]
        try:
            response = requests.get(config["url"], timeout=5)
            data = response.json()
            
            if data.get("content"):
                author = data.get("author", "Unknown")
                return f"✨ {data['content']}\n— {author}"
            else:
                return "Quote nahi mila."
        except Exception as e:
            log.error(f"Quote API error: {e}")
            return "Aaj ka motivation: 'Believe in yourself!' 🌟"
    
    @staticmethod
    def get_cat_fact() -> str:
        """Get a random cat fact"""
        config = API_CONFIG["cat_fact"]
        try:
            response = requests.get(config["url"], timeout=5)
            data = response.json()
            return f"🐱 Cat Fact: {data.get('fact', 'No fact found')}"
        except Exception as e:
            log.error(f"Cat fact API error: {e}")
            return "Cats are mysterious creatures! 🐱"
    
    @staticmethod
    def get_advice() -> str:
        """Get random advice"""
        config = API_CONFIG["advice"]
        try:
            response = requests.get(config["url"], timeout=5)
            data = response.json()
            slip = data.get("slip", {})
            return f"💡 Advice: {slip.get('advice', 'No advice found')}"
        except Exception as e:
            log.error(f"Advice API error: {e}")
            return "My advice: Take a deep breath and smile! 😊"
    
    @staticmethod
    def get_chuck_norris_joke() -> str:
        """Get Chuck Norris joke"""
        config = API_CONFIG["chuck_norris"]
        try:
            response = requests.get(config["url"], timeout=5)
            data = response.json()
            return f"💪 Chuck Norris says: {data.get('value', 'He is the best!')}"
        except Exception as e:
            log.error(f"Chuck Norris API error: {e}")
            return "Chuck Norris doesn't need APIs, APIs call him!"
    
    @staticmethod
    def get_astronauts() -> str:
        """Get number of astronauts in space"""
        config = API_CONFIG["space"]
        try:
            response = requests.get(config["url"], timeout=5)
            data = response.json()
            count = data.get("number", 0)
            people = data.get("people", [])
            names = [p["name"] for p in people[:3]]
            return f"🌌 Space mein {count} astronaut hain. {', '.join(names)} aur doosre. Amazing!"
        except Exception as e:
            log.error(f"Space API error: {e}")
            return "Space information nahi mili. Maybe astronauts are busy! 🚀"
    
    @staticmethod
    def get_definition(word: str) -> str:
        """Get dictionary definition"""
        config = API_CONFIG["dictionary"]
        try:
            response = requests.get(f"{config['url']}{word}", timeout=5)
            if response.status_code == 200:
                data = response.json()
                if data:
                    meanings = data[0].get("meanings", [])
                    if meanings:
                        definition = meanings[0].get("definitions", [{}])[0].get("definition", "No definition found")
                        part_of_speech = meanings[0].get("partOfSpeech", "")
                        return f"📖 {word}: {definition} ({part_of_speech})"
            return f"'{word}' ka definition nahi mila. Word sahi hai?"
        except Exception as e:
            log.error(f"Dictionary API error: {e}")
            return "Dictionary check nahi ho paya."
    
    @staticmethod
    def get_random_user() -> str:
        """Get random user information"""
        config = API_CONFIG["random_user"]
        try:
            response = requests.get(config["url"], timeout=5)
            data = response.json()
            if data.get("results"):
                user = data["results"][0]
                name = f"{user['name']['first']} {user['name']['last']}"
                country = user["location"]["country"]
                email = user["email"]
                return f"👤 Random user: {name} from {country}. Email: {email}"
            return "Random user nahi mila."
        except Exception as e:
            log.error(f"Random user API error: {e}")
            return "Random user fetch nahi ho paya."


