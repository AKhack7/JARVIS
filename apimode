def smart_open(command: str) -> str:
    """Open app or setting using fuzzy matching."""
    all_keys = list(APPS.keys()) + list(SETTINGS.keys())
    words = command.split()

    # Direct match
    for app in APPS:
        if app in command:
            os.system(APPS[app])
            return f"'{app}' open kar raha hu 🚀"

    for setting in SETTINGS:
        if setting in command:
            os.system(f"start {SETTINGS[setting]}")
            return f"'{setting}' settings open kar raha hu ⚙️"

    # Fuzzy
    match = get_close_matches(command, all_keys, n=1, cutoff=0.45)
    if match:
        key = match[0]
        if key in APPS:
            os.system(APPS[key])
            return f"'{key}' open kar raha hu 🚀"
        elif key in SETTINGS:
            os.system(f"start {SETTINGS[key]}")
            return f"'{key}' settings open kar raha hu ⚙️"

    return ""

