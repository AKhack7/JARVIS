gesture_thread_running = False

def start_gesture_mode():
    """Run gesture recognition in background thread."""
    if not GESTURE_AVAILABLE:
        speak("MediaPipe ya OpenCV install nahi hai. Gesture mode unavailable.")
        return

    global gesture_thread_running
    if gesture_thread_running:
        speak("Gesture mode pehle se chal raha hai.")
        return

    gesture_thread_running = True
    speak("Gesture mode on! Open palm dikhao activate karne ke liye.")

    def _run():
        global gesture_thread_running
        mp_hands = mp.solutions.hands
        hands_detector = mp_hands.Hands(min_detection_confidence=0.7)
        cap = cv2.VideoCapture(0)

        gesture_active = False
        last_action_t = 0
        prev_x = 0

        def _dist(p1, p2):
            return math.hypot(p1.x - p2.x, p1.y - p2.y)

        def _is_fist(hand):
            return all(hand.landmark[t].y > hand.landmark[t-2].y for t in [8,12,16,20])

        def _is_palm(hand):
            return all(hand.landmark[t].y < hand.landmark[t-2].y for t in [8,12,16,20])

        def _is_pinch(hand):
            return _dist(hand.landmark[4], hand.landmark[8]) < 0.05

        def _fingers_up(hand):
            return [hand.landmark[t].y < hand.landmark[t-2].y for t in [8,12,16,20]]

        while gesture_thread_running:
            ret, frame = cap.read()
            if not ret:
                continue
            frame = cv2.flip(frame, 1)
            rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            result = hands_detector.process(rgb)

            if result.multi_hand_landmarks:
                for hand in result.multi_hand_landmarks:
                    x = hand.landmark[8].x

                    if _is_palm(hand):
                        if time.time() - last_action_t > 2:
                            gesture_active = not gesture_active
                            speak("Gesture " + ("activated" if gesture_active else "deactivated"))
                            last_action_t = time.time()

                    if not gesture_active:
                        continue

                    sw, sh = pyautogui.size()
                    sx = int(hand.landmark[8].x * sw)
                    sy = int(hand.landmark[8].y * sh)
                    pyautogui.moveTo(sx, sy)

                    if _is_pinch(hand):
                        pyautogui.mouseDown()
                    else:
                        pyautogui.mouseUp()

                    if _is_fist(hand) and time.time() - last_action_t > 2:
                        take_screenshot()
                        speak("Screenshot liya!")
                        last_action_t = time.time()

                    f = _fingers_up(hand)

                    if f == [True, True, False, False] and time.time() - last_action_t > 2:
                        cv2.imwrite(datetime.now().strftime("%Y-%m-%d_%H-%M-%S") + "_gesture.jpg", frame)
                        speak("Photo!")
                        last_action_t = time.time()

                    # Swipe
                    if prev_x != 0:
                        dx = x - prev_x
                        if dx > 0.15:
                            pyautogui.hotkey("alt", "tab")
                        elif dx < -0.15:
                            pyautogui.hotkey("alt", "shift", "tab")
                    prev_x = x

                    # Volume
                    if not any(f) and hand.landmark[4].y < hand.landmark[3].y:
                        pyautogui.press("volumeup")
                    elif not any(f) and hand.landmark[4].y > hand.landmark[3].y:
                        pyautogui.press("volumedown")

            if cv2.waitKey(1) & 0xFF == ord('q'):
                break

        cap.release()
        cv2.destroyAllWindows()
        gesture_thread_running = False

    threading.Thread(target=_run, daemon=True).start()

def stop_gesture_mode():
    global gesture_thread_running
    gesture_thread_running = False
    speak("Gesture mode off.")


