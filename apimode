def extract_city_name(cmd: str) -> str:
    """Extract city name from weather command"""
    words = cmd.split()
    city_keywords = ["in", "of", "ka", "mein", "weather", "mausam", "temperature", "temp", "for"]
    
    for i, word in enumerate(words):
        if word in ["in", "of", "ka", "mein", "for", "at"] and i + 1 < len(words):
            return words[i + 1]
    
    # Remove common keywords
    for kw in city_keywords:
        cmd = cmd.replace(kw, "")
    
    cleaned = " ".join([w for w in cmd.split() if w not in city_keywords])
    if cleaned.strip():
        return cleaned.strip()
    
    return None

def extract_word_for_definition(cmd: str) -> str:
    """Extract word for definition"""
    words = cmd.split()
    # Look for patterns like "meaning of X" or "define X"
    for i, word in enumerate(words):
        if word in ["meaning", "definition", "define", "matlab", "of"]:
            if i + 1 < len(words):
                return words[i + 1]
    
    # If no pattern found, take the last word (might be the word)
    if words:
        return words[-1]
    return None


