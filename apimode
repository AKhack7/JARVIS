tts_engine = None

def init_tts():
    global tts_engine
    if TTS_AVAILABLE:
        try:
            tts_engine = pyttsx3.init()
            voices = tts_engine.getProperty('voices')
            # Try to find female voice
            for v in voices:
                if "female" in v.name.lower() or "zira" in v.name.lower() or "hazel" in v.name.lower():
                    tts_engine.setProperty('voice', v.id)
                    break
            tts_engine.setProperty('rate', 185)
            tts_engine.setProperty('volume', 1.0)
        except Exception as e:
            log.warning(f"TTS init failed: {e}")
            tts_engine = None

init_tts()

_tts_lock = threading.Lock()

def speak(text: str):
    """Speak text aloud and display in GUI."""
    print(f"[ISHA] {text}")
    if app_instance:
        app_instance.show_response(text)
    if tts_engine:
        def _speak():
            with _tts_lock:
                try:
                    tts_engine.say(text)
                    tts_engine.runAndWait()
                except:
                    pass
        threading.Thread(target=_speak, daemon=True).start()

app_instance = None  # Will be set when GUI launches


