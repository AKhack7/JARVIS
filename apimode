        self.response_after = None

        # Position bottom-center
        sw = self.root.winfo_screenwidth()
        sh = self.root.winfo_screenheight()
        w, h = 560, 66
        self.root.geometry(f"{w}x{h}+{(sw-w)//2}+{sh-h-60}")

        self._build_ui()
        self._greet()

    # ── Build UI ────────────────────────────────────────────────

    def _build_ui(self):
        self.canvas = tk.Canvas(
            self.root, width=560, height=66,
            bg=self.BG, highlightthickness=0
        )
        self.canvas.pack()
        self._draw_capsule()
        self._draw_mic_btn()
        self._draw_search()
        self._draw_settings_btn()
        self._draw_apps_btn()
        self._draw_api_btn()

    def _draw_capsule(self):
        """Draw the main capsule shape."""
        pad, h = 8, 50
        r = h // 2
        x1, y1 = pad, 8
        x2, y2 = 552, 58

        # Shadow
        self.canvas.create_arc(x1+2, y1+2, x1+h+2, y2+2,
                                start=90, extent=180,
                                fill="#050508", outline="")
        self.canvas.create_arc(x2-h-2, y1+2, x2+2, y2+2,
                                start=270, extent=180,
                                fill="#050508", outline="")
        self.canvas.create_rectangle(x1+r+2, y1+2, x2-r+2, y2+2,
                                     fill="#050508", outline="")

        # Body
        self.canvas.create_arc(x1, y1, x1+h, y2, start=90, extent=180,
                                fill=self.CAPSULE_BG, outline=self.CAPSULE_BD)
        self.canvas.create_arc(x2-h, y1, x2, y2, start=270, extent=180,
                                fill=self.CAPSULE_BG, outline=self.CAPSULE_BD)
        self.canvas.create_rectangle(x1+r, y1, x2-r, y2,
                                     fill=self.CAPSULE_BG, outline="")
        # Top/bottom border lines
        self.canvas.create_line(x1+r, y1, x2-r, y1, fill=self.CAPSULE_BD, width=1)
        self.canvas.create_line(x1+r, y2, x2-r, y2, fill=self.CAPSULE_BD, width=1)

    def _draw_mic_btn(self):
        """Circular mic button on the left."""
        cx, cy, r = 41, 33, 20
        self.mic_oval = self.canvas.create_oval(
            cx-r, cy-r, cx+r, cy+r,
            fill=self.MIC_OFF, outline="", tags="mic_btn"
        )
        # Mic icon
        self.mic_icon = self.canvas.create_text(
            cx, cy, text="🎤", font=("Segoe UI Emoji", 12), tags="mic_btn"
        )
        self.canvas.tag_bind("mic_btn", "<Button-1>", self._toggle_mic)
        self.canvas.tag_bind("mic_btn", "<Enter>",
            lambda e: self.canvas.config(cursor="hand2"))
        self.canvas.tag_bind("mic_btn", "<Leave>",
            lambda e: self.canvas.config(cursor=""))

    def _draw_search(self):
        """Search bar in the middle."""
        # Input field frame via canvas window
        self.search_var = tk.StringVar()
        self.search_entry = tk.Entry(
            self.root,
            textvariable=self.search_var,
            font=("Segoe UI", 11),
            bg="#1A1A28", fg=self.TEXT_MAIN,
            insertbackground=self.ACCENT,
            relief="flat", bd=0,
            highlightthickness=0
        )
        self.canvas.create_window(
            285, 33, window=self.search_entry, width=340, height=30
        )
        # Placeholder
        self._set_placeholder()
        self.search_entry.bind("<FocusIn>",  self._clear_placeholder)
        self.search_entry.bind("<FocusOut>", self._restore_placeholder)
        self.search_entry.bind("<Return>",   self._on_search_enter)

    def _set_placeholder(self):
        self.search_entry.insert(0, "Ask Isha anything...")
        self.search_entry.config(fg=self.TEXT_DIM)
        self._is_placeholder = True

    def _clear_placeholder(self, e=None):
        if getattr(self, "_is_placeholder", False):
            self.search_entry.delete(0, tk.END)
            self.search_entry.config(fg=self.TEXT_MAIN)
            self._is_placeholder = False

    def _restore_placeholder(self, e=None):
        if not self.search_var.get():
            self._set_placeholder()

    def _on_search_enter(self, e=None):
        text = self.search_var.get().strip()
        if text and text != "Ask Isha anything...":
            self.search_entry.delete(0, tk.END)
            self._set_placeholder()
            threading.Thread(target=self._handle_command, args=(text,), daemon=True).start()

    def _draw_settings_btn(self):
        """Circular settings button on the right."""
        cx, cy, r = 519, 33, 20
        self.settings_oval = self.canvas.create_oval(
            cx-r, cy-r, cx+r, cy+r,
            fill=self.BTN_BG, outline=self.CAPSULE_BD, tags="settings_btn"
