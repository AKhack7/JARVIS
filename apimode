def main():
    root = tk.Tk()

    # Remove default window decorations — we use overrideredirect for full custom look
    # Keep normal window so it appears in taskbar
    root.configure(bg="#0A0A0F")

    # Make background transparent if possible (Windows)
    try:
        root.attributes("-transparentcolor", "#0A0A0F")
    except:
        pass

    app = IshaGUI(root)

    # Keyboard shortcut to quit
    root.bind("<Escape>", lambda e: root.destroy())

    # Tray-like drag support
    _drag = {"x": 0, "y": 0}

    def _start_drag(e):
        _drag["x"] = e.x_root - root.winfo_x()
        _drag["y"] = e.y_root - root.winfo_y()

    def _do_drag(e):
        root.geometry(f"+{e.x_root-_drag['x']}+{e.y_root-_drag['y']}")

    app.canvas.bind("<ButtonPress-3>",  _start_drag)
    app.canvas.bind("<B3-Motion>",      _do_drag)

    root.mainloop()


if __name__ == "__main__":
    main()