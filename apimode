            self.apps_popup.destroy()
            self.apps_popup = None
            return
        self._open_apps_popup()

    def _open_apps_popup(self):
        popup = tk.Toplevel(self.root)
        popup.overrideredirect(True)
        popup.attributes("-topmost", True)
        popup.configure(bg=self.POPUP_BG)
        self.apps_popup = popup

        rx = self.root.winfo_x()
        ry = self.root.winfo_y()

        # Header
        header = tk.Frame(popup, bg=self.POPUP_BG, pady=8)
        header.pack(fill="x", padx=12)
        tk.Label(header, text="ISHA Launcher",
                 font=("Segoe UI", 10, "bold"),
                 fg=self.GOLD, bg=self.POPUP_BG).pack()

        sep = tk.Frame(popup, bg=self.CAPSULE_BD, height=1)
        sep.pack(fill="x", padx=12)

        # Segmented control
        tab_frame = tk.Frame(popup, bg=self.POPUP_BG, pady=6)
        tab_frame.pack(fill="x", padx=12)

        self._active_tab = tk.StringVar(value="apps")
        content_frame = tk.Frame(popup, bg=self.POPUP_BG)
        content_frame.pack(fill="both", expand=True, padx=8)

        def _switch(tab):
            self._active_tab.set(tab)
            for w in content_frame.winfo_children():
                w.destroy()
            if tab == "apps":
                apk_btn.config(bg=self.ACCENT, fg="#FFF")
                set_btn.config(bg=self.BTN_BG, fg=self.TEXT_DIM)
                _build_list(content_frame, list(APPS.keys()), "app")
            else:
                set_btn.config(bg=self.ACCENT, fg="#FFF")
                apk_btn.config(bg=self.BTN_BG, fg=self.TEXT_DIM)
                _build_list(content_frame, list(SETTINGS.keys()), "setting")

        apk_btn = tk.Button(
            tab_frame, text="  Apps  ",
            font=("Segoe UI", 9, "bold"),
            fg="#FFF", bg=self.ACCENT,
            relief="flat", bd=0, cursor="hand2", padx=10, pady=4,
            command=lambda: _switch("apps")
        )
        apk_btn.pack(side="left", padx=2)

        set_btn = tk.Button(
            tab_frame, text="  Settings  ",
            font=("Segoe UI", 9, "bold"),
            fg=self.TEXT_DIM, bg=self.BTN_BG,
            relief="flat", bd=0, cursor="hand2", padx=10, pady=4,
            command=lambda: _switch("settings")
        )
        set_btn.pack(side="left", padx=2)

        # Search inside popup
        search_var = tk.StringVar()
        search_box = tk.Entry(
            tab_frame, textvariable=search_var,
            font=("Segoe UI", 9),
            fg=self.TEXT_MAIN, bg=self.BTN_BG,
            insertbackground=self.ACCENT,
            relief="flat", bd=0, highlightthickness=1,
            highlightcolor=self.ACCENT
        )
        search_box.pack(side="right", padx=4, ipadx=6, ipady=3)

        def _build_list(parent, items, kind, filter_text=""):
            for w in parent.winfo_children():
                w.destroy()
            filtered = [i for i in items if filter_text.lower() in i.lower()]

            # Scrollable canvas
            canvas = tk.Canvas(parent, bg=self.POPUP_BG, highlightthickness=0,
                               width=340, height=260)
            scrollbar = tk.Scrollbar(parent, orient="vertical", command=canvas.yview)
            canvas.configure(yscrollcommand=scrollbar.set)
            canvas.pack(side="left", fill="both", expand=True)
            scrollbar.pack(side="right", fill="y")

            inner = tk.Frame(canvas, bg=self.POPUP_BG)
            canvas.create_window((0, 0), window=inner, anchor="nw")

            def _on_frame_configure(e):
                canvas.configure(scrollregion=canvas.bbox("all"))
            inner.bind("<Configure>", _on_frame_configure)

            for item in filtered:
                def _make_open(k=item, t=kind):
                    def _open():
                        if t == "app":
                            os.system(APPS.get(k, ""))
                            speak(f"{k} open kar raha hu")
                        else:
                            os.system(f"start {SETTINGS.get(k, '')}")
                            speak(f"{k} settings open kar raha hu")
                        popup.destroy()
                    return _open

                row = tk.Frame(inner, bg=self.POPUP_BG)
                row.pack(fill="x", pady=1)

                icon = "🚀" if kind == "app" else "⚙"
                btn = tk.Button(
                    row,
                    text=f" {icon}  {item.title()}",
                    font=("Segoe UI", 9),
                    fg=self.TEXT_MAIN, bg=self.POPUP_BG,
                    activeforeground=self.ACCENT,
                    activebackground=self.BTN_HOVER,
                    relief="flat", bd=0, cursor="hand2",
                    anchor="w", width=36, pady=3,
                    command=_make_open()
                )
                btn.pack(fill="x", padx=4)

                def _e(e, b=btn): b.config(bg=self.BTN_HOVER)
                def _l(e, b=btn): b.config(bg=self.POPUP_BG)
                btn.bind("<Enter>", _e)
                btn.bind("<Leave>", _l)

            canvas.bind("<MouseWheel>",
                lambda e: canvas.yview_scroll(-1*(e.delta//120), "units"))

        def _on_search(*args):
            txt = search_var.get()
            tab = self._active_tab.get()
            if tab == "apps":
                _build_list(content_frame, list(APPS.keys()), "app", txt)
            else:
                _build_list(content_frame, list(SETTINGS.keys()), "setting", txt)

        search_var.trace("w", _on_search)

        # Close btn
        close_frame = tk.Frame(popup, bg=self.POPUP_BG, pady=4)
        close_frame.pack(fill="x")
        tk.Button(
            close_frame, text="✕ Close",
            font=("Segoe UI", 8),
            fg=self.TEXT_DIM, bg=self.POPUP_BG,
            activeforeground=self.ACCENT2,
            relief="flat", bd=0, cursor="hand2",
            command=popup.destroy
        ).pack()

        # Initial content
        _build_list(content_frame, list(APPS.keys()), "app")

        popup.update_idletasks()
        pw = popup.winfo_width()
        ph = popup.winfo_height()
        popup.geometry(f"+{rx + 10}+{ry - ph - 8}")
        popup.configure(highlightbackground=self.CAPSULE_BD, highlightthickness=1)

