def parse_alarm(cmd: str):
    import re
    match = re.search(r'(\d{1,2}:\d{2})', cmd)
    if match:
        alarm_time = match.group(1)
        def _alarm():
            speak(f"Alarm set {alarm_time} ke liye")
            while True:
                now = datetime.now().strftime("%H:%M")
                if now == alarm_time:
                    speak("Alarm baj raha hai! Wake up! ⏰")
                    break
                time.sleep(30)
        threading.Thread(target=_alarm, daemon=True).start()
        return f"Alarm set ho gaya {alarm_time} ke liye ⏰"
    return "Alarm time batao, jaise: alarm 07:30"

def parse_reminder(cmd: str):
    import re
    match = re.search(r'(\d+)\s*second', cmd)
    if match:
        secs = int(match.group(1))
        msg_match = re.search(r'(?:baad|after)[^a-z]*(.+)', cmd)
        msg = msg_match.group(1) if msg_match else "Reminder!"
        def _remind():
            time.sleep(secs)
            speak(f"Reminder: {msg}")
        threading.Thread(target=_remind, daemon=True).start()
        return f"Reminder set ho gaya {secs} seconds baad 🔔"
    return "Format: 30 second baad yaad dilao [message]"


