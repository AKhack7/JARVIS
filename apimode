def load_api_keys():
    """Load API keys from file"""
    try:
        if os.path.exists(API_KEYS_FILE):
            with open(API_KEYS_FILE, "r") as f:
                keys = json.load(f)
                for service, config in API_CONFIG.items():
                    if service in keys:
                        config["key"] = keys[service]
                        if config["key"]:
                            config["enabled"] = True
    except Exception as e:
        log.warning(f"Error loading API keys: {e}")

def save_api_keys():
    """Save API keys to file"""
    try:
        keys = {}
        for service, config in API_CONFIG.items():
            if config.get("key"):
                keys[service] = config["key"]
        with open(API_KEYS_FILE, "w") as f:
            json.dump(keys, f, indent=2)
    except Exception as e:
        log.warning(f"Error saving API keys: {e}")

load_api_keys()


