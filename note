🔷

def check_voice():
    global active
    try:
        with sr.Microphone() as source:
            audio = recognizer.listen(source, timeout=1, phrase_time_limit=2)
            command = recognizer.recognize_google(audio).lower()

            if "activate signal" in command:
                active = True
                speak("Activated")

            elif "deactivate signal" in command:
                active = False
                speak("Deactivated")
    except:
        pass

# ===== MAIN LOOP =====
while True:
    check_voice()  # voice check

    ret, frame = cap.read()
    if not ret:
        continue

    frame = cv2.flip(frame, 1)
    rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
    result = hands.process(rgb)

    if active and result.multi_hand_landmarks:
        for hand in result.multi_hand_landmarks:

            # finger positions
            index = hand.landmark[8].y < hand.landmark[6].y
            middle = hand.landmark[12].y < hand.landmark[10].y
            ring = hand.landmark[16].y < hand.landmark[14].y
            pinky = hand.landmark[20].y < hand.landmark[18].y

            # ===== SIMPLE SIGN LOGIC =====

            # 👋 Open hand
            if index and middle and ring and pinky:
                sign = "Hello"

            # ✌️ 2 fingers
            elif index and middle and not ring and not pinky:
                sign = "No"

            # ✊ fist
            elif not index and not middle and not ring and not pinky:
                sign = "Yes"

            # 👌 (approx: index + thumb close)
            elif abs(hand.landmark[4].x - hand.landmark[8].x) < 0.05:
                sign = "OK"

            else:
                sign = None

            # ===== SPEAK =====
            if sign and time.time() - last_time > 2:
                speak(sign)
                last_time = time.time()

    # exit
    if cv2.waitKey(1) == 27:
        break

cap.release()
cv2.destroyAllWindows()