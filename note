    "select all": ["ctrl", "a"],
    "copy": ["ctrl", "c"],
    "paste": ["ctrl", "v"],
    "cut": ["ctrl", "x"],
    "undo": ["ctrl", "z"],
    "redo": ["ctrl", "y"],
    "save": ["ctrl", "s"],
    "print": ["ctrl", "p"],

    "new tab": ["ctrl", "t"],
    "close tab": ["ctrl", "w"],
    "refresh": ["ctrl", "r"],

    "switch window": ["alt", "tab"],
    "close window": ["alt", "f4"],

    "find": ["ctrl", "f"],
    "zoom in": ["ctrl", "+"],
    "zoom out": ["ctrl", "-"],

    "screenshot": ["win", "shift", "s"]
}


🔷 Smart Action Detection (Hinglish)

Code :-
def detect_action(command):
    command = command.lower()

    if "select" in command:
        return "select all"

    elif "copy" in command:
        return "copy"

    elif "paste" in command:
        return "paste"

    elif "delete" in command:
        return "cut"

    elif "undo" in command:
        return "undo"

    elif "save" in command:
        return "save"

    elif "refresh" in command:
        return "refresh"

    elif "band karo" in command or "close" in command:
        return "close window"

    return None

🔷 Execute Smart Shortcut
Code :-
import pyautogui

def perform_action(action):
    if action in action_map:
        keys = action_map[action]
        pyautogui.hotkey(*keys)
        speak(f"{action} kar diya")
    else:
        speak("Iska shortcut mujhe nahi pata")

🔷 Gaming Shortcuts
Code :-
def game_control(command):

    if "jump" in command:
        pyautogui.press("space")

    elif "shoot" in command:
        pyautogui.click()

    elif "reload" in command:
        pyautogui.press("r")

    elif "run" in command:
        pyautogui.keyDown("shift")

    elif "stop running" in command:
        pyautogui.keyUp("shift")


🔷 Mouse Control by Voice

Code :- def mouse_control(command):

    if "left click" in command:
        pyautogui.click()

    elif "right click" in command:
        pyautogui.rightClick()

    elif "scroll up" in command:
        pyautogui.scroll(500)

    elif "scroll down" in command:
        pyautogui.scroll(-500)

    elif "move mouse" in command:
        pyautogui.moveTo(500, 500)

🔷 File Open System

Code :-
import os

def open_file(command):

    if "notepad" in command:
        os.system("notepad")

    elif "chrome" in command:
        os.system("start chrome")

    elif "calculator" in command:
        os.system("calc")

🔷 Custom Shortcut Training (🔥 Powerful)

Code :-
custom_actions = {}

def train_shortcut(command, action, keys):
    custom_actions[action] = keys
    speak(f"{action} save ho gaya")

def run_custom_action(command):
    for action in custom_actions:
        if action in command:
            pyautogui.hotkey(*custom_actions[action])
            return True
    return False

🔷 Website Open System (important for you)

Code :-
import webbrowser

def open_website(query):
    sites = {
        "youtube": "https://www.youtube.com",
        "google": "https://www.google.com",
        "instagram": "https://www.instagram.com",
        "whatsapp": "https://web.whatsapp.com",
        "facebook": "https://www.facebook.com"
    }

    for name in sites:
        if name in query.lower():
            webbrowser.open(sites[name])
            return f"{name} open kar raha hu"

    return None


🔷 Hinglish Smart Understanding

Code :-
def detect_intent(text):
    text = text.lower()

    if any(word in text for word in ["open", "kholo", "chalu karo"]):
        return "open"

    elif any(word in text for word in ["kya hai", "kaun hai", "kaise", "what", "who"]):
        return "search"

    elif any(word in text for word in ["play", "song", "gaana"]):
        return "youtube"

    else:
        return "unknown"

🔷 Better Google Parsing (Improved)

Code :- def google_search(query):
    try:
        url = f"https://www.google.com/search?q={query}"
        headers = {"User-Agent": "Mozilla/5.0"}

        res = requests.get(url, headers=headers)
        soup = BeautifulSoup(res.text, "html.parser")

        # Multiple attempts
        answer = soup.find("div", class_="BNeawe")
        if answer:
            return answer.text

        answer2 = soup.find("span")
        if answer2:
            return answer2.text

        return "Mujhe clear result nahi mila"

    except:
        return "Internet error"

🔷 Code (Auto Play YouTube Song)
Code :- import pywhatkit as kit

def play_youtube_song(query):
    try:
        speak("YouTube par play kar raha hu")
        kit.playonyt(query)   # auto search + auto play
    except:
        speak("Song play nahi ho paya")


