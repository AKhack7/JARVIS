Example code :-

👉 import os

def open_app_or_setting(command):

    command = command.lower()

    # 🔍 Apps check
    for app in apps:
        if app in command:
            os.system(apps[app])
            speak(f"{app} open kar raha hu")
            return True

    # ⚙️ Settings check
    for setting in settings:
        if setting in command:
            os.system(f"start {settings[setting]}")
            speak(f"{setting} setting open kar raha hu")
            return True

    return False


👉 from difflib import get_close_matches

def smart_open(command):

    command = command.lower()
    all_keys = list(apps.keys()) + list(settings.keys())

    match = get_close_matches(command, all_keys, n=1, cutoff=0.5)

    if match:
        key = match[0]

        if key in apps:
            os.system(apps[key])
            speak(f"{key} open kar raha hu")

        elif key in settings:
            os.system(f"start {settings[key]}")
            speak(f"{key} setting open kar raha hu")

        return True

    return False
