
🔷 SCREENSHOT SYSTEM (No overwrite 🔥
Code :- import pyautogui
import os
from datetime import datetime

def take_screenshot():
    folder = "screenshots"
    
    if not os.path.exists(folder):
        os.makedirs(folder)

    # unique filename (date + time)
    filename = datetime.now().strftime("%Y-%m-%d_%H-%M-%S") + ".png"
    path = os.path.join(folder, filename)

    screenshot = pyautogui.screenshot()
    screenshot.save(path)

    speak("Screenshot save ho gaya")
    print("Saved at:", path)

🔷 SCREEN RECORDING SYSTEM

Code :-
import cv2
import numpy as np

def screen_record(duration=10):
    speak("Screen recording start ho rahi hai")

    screen_size = pyautogui.size()
    fourcc = cv2.VideoWriter_fourcc(*"XVID")

    filename = datetime.now().strftime("%Y-%m-%d_%H-%M-%S") + ".avi"
    out = cv2.VideoWriter(filename, fourcc, 20.0, screen_size)

    start_time = datetime.now()

    while (datetime.now() - start_time).seconds < duration:
        img = pyautogui.screenshot()
        frame = np.array(img)
        frame = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)

        out.write(frame)

    out.release()
    speak("Recording save ho gayi")

🔷 SELFIE SYSTEM (Webcam)

Code :- def take_selfie():
    speak("Camera open kar raha hu")

    cam = cv2.VideoCapture(0)

    ret, frame = cam.read()

    if ret:
        filename = datetime.now().strftime("%Y-%m-%d_%H-%M-%S") + ".jpg"
        cv2.imwrite(filename, frame)
        speak("Selfie save ho gayi")
    else:
        speak("Camera error")

    cam.release()

🔷 INTENT ADD KARO

Code :- def detect_media_command(command):
    command = command.lower()

    if "screenshot" in command:
        return "screenshot"

    elif "record" in command:
        return "record"

    elif "selfie" in command or "photo" in command:
        return "selfie"

    return None


🔷IP ADDRESS + INTERNET SPEED
import socket
import speedtest

def check_ip():
    hostname = socket.gethostname()
    ip = socket.gethostbyname(hostname)
    speak(f"Your IP address is {ip}")
    print("IP:", ip)

def check_speed():
    speak("Internet speed check kar raha hu")
    st = speedtest.Speedtest()

    download = st.download() / 1_000_000
    upload = st.upload() / 1_000_000

    speak(f"Download speed {round(download,2)} Mbps hai")
    speak(f"Upload speed {round(upload,2)} Mbps hai")
✅ Example:
👉 “IP batao” → IP address
👉 “internet speed check karo” → speed result
⏰ 2. ALARM SYSTEM


import time
from datetime import datetime

def set_alarm(alarm_time):
    speak(f"Alarm set ho gaya {alarm_time}")

    while True:
        now = datetime.now().strftime("%H:%M")
        if now == alarm_time:
            speak("Alarm baj raha hai")
            break
✅ Example:
👉 “alarm 07:30 set karo”
🔔 3. REMINDER SYSTEM


import threading

def set_reminder(seconds, message):
    def remind():
        time.sleep(seconds)
        speak(f"Reminder: {message}")

    threading.Thread(target=remind).start()
✅ Example:
👉 “10 second baad yaad dilana pani piyo”
📅 4. DATE, TIME, DAY


def tell_time():
    now = datetime.now()
    speak(f"Time hai {now.strftime('%H:%M')}")

def tell_date():
    now = datetime.now()
    speak(f"Aaj date hai {now.strftime('%d %B %Y')}")

def tell_day():
    now = datetime.now()
    speak(f"Aaj {now.strftime('%A')} hai")
✅ Example:
👉 “time kya hai”
👉 “aaj ka din kya hai”
🧮 5. MATH SOLVER (🔥 Powerful)
👉 Ye sab handle karega:
/ √
decimal (.86 + 4)
π ₹ € ¥ etc.

from sympy import sympify


def solve_math(expr):
    try:
        expr = expr.replace("×", "*").replace("÷", "/")
        expr = expr.replace("√", "sqrt")
        expr = expr.replace("π", "pi")

        result = sympify(expr)
        speak(f"Answer hai {result}")
        print("Result:", result)

    except:
        speak("Ye solve nahi ho paya")
✅ Examples:
👉 Input: 2+7 → 9
👉 Input: 57.97+8 → 65.97
👉 Input: .86+4 → 4.86
👉 Input: √16 → 4
👉 Input: π*2 → 6.28 approx

🔷 ADVANCED ISHA GESTURE

Code :-
import cv2
import mediapipe as mp
import pyautogui
import time
import math
import os
import subprocess

# ===== INIT =====
mp_hands = mp.solutions.hands
hands = mp_hands.Hands(min_detection_confidence=0.7)
cap = cv2.VideoCapture(0)

gesture_active = False
last_action = 0
prev_x, prev_y = 0, 0

# ===== FUNCTIONS =====

def distance(p1, p2):
    return math.hypot(p1.x - p2.x, p1.y - p2.y)

def is_fist(hand):
    tips = [8, 12, 16, 20]
    return all(hand.landmark[t].y > hand.landmark[t-2].y for t in tips)

def is_open_palm(hand):
    return all(hand.landmark[t].y < hand.landmark[t-2].y for t in [8,12,16,20])

def is_pinch(hand):
    return distance(hand.landmark[4], hand.landmark[8]) < 0.05

def fingers_up(hand):
    return [
        hand.landmark[8].y < hand.landmark[6].y,
        hand.landmark[12].y < hand.landmark[10].y,
        hand.landmark[16].y < hand.landmark[14].y,
        hand.landmark[20].y < hand.landmark[18].y
    ]

# ===== MAIN LOOP =====

while True:
    ret, frame = cap.read()
    if not ret:
        continue

    frame = cv2.flip(frame, 1)
    rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
    result = hands.process(rgb)

    if result.multi_hand_landmarks:
        for hand in result.multi_hand_landmarks:

            x = hand.landmark[8].x
            y = hand.landmark[8].y

            screen_w, screen_h = pyautogui.size()
            screen_x = int(x * screen_w)
            screen_y = int(y * screen_h)

            # ===== ACTIVATE / DEACTIVATE =====
            if is_open_palm(hand):
                if time.time() - last_action > 2:
                    gesture_active = not gesture_active
                    print("Gesture Mode:", gesture_active)
                    last_action = time.time()

            if not gesture_active:
                continue

            # ===== AIR MOUSE =====
            pyautogui.moveTo(screen_x, screen_y)

            # ===== CLICK / DRAG =====
            if is_pinch(hand):
                pyautogui.mouseDown()
            else:
                pyautogui.mouseUp()

            # ===== SCREENSHOT =====
            if is_fist(hand):
                if time.time() - last_action > 2:
                    pyautogui.screenshot("screenshot.png")
                    print("Screenshot")
                    last_action = time.time()

            # ===== FINGER PATTERN =====
            f = fingers_up(hand)

            # ✌️ 2 fingers → Camera Photo
            if f == [True, True, False, False]:
                if time.time() - last_action > 2:
                    cv2.imwrite("photo.png", frame)
                    print("Photo Captured")
                    last_action = time.time()

            # 👍 Thumb only → Volume Up
            if f == [False, False, False, False] and hand.landmark[4].y < hand.landmark[3].y:
                pyautogui.press("volumeup")

            # 👇 All down → Volume Down
            if f == [False, False, False, False] and hand.landmark[4].y > hand.landmark[3].y:
                pyautogui.press("volumedown")

            # ===== SWIPE (APP SWITCH) =====
            if prev_x != 0:
                dx = x - prev_x

                if dx > 0.15:
                    pyautogui.hotkey("alt", "tab")

                elif dx < -0.15:
                    pyautogui.hotkey("alt", "shift", "tab")

            prev_x = x

            # ===== ZOOM CONTROL =====
            if distance(hand.landmark[8], hand.landmark[12]) > 0.1:
                pyautogui.hotkey("ctrl", "+")

            elif distance(hand.landmark[8], hand.landmark[12]) < 0.05:
                pyautogui.hotkey("ctrl", "-")

            # ===== APP OPEN (CUSTOM) =====
            if f == [True, False, False, False]:  # only index
                subprocess.Popen("notepad.exe")

            # ===== FILE OPEN =====
            if f == [False, True, False, False]:  # only middle
                try:
                    os.startfile("C:\\Users\\Public\\Documents")
                except:
                    pass

            # ===== STOP SYSTEM =====
            if f == [True, True, True, True]:
                print("System Stopped")
                gesture_active = False

    # emergency exit
    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

cap.release()
cv2.destroyAllWindows()



