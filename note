🔷 Advanced Upgrade (optional but awesome)
Code:-
Python id="cleanquery1"
def clean_query(query):
    remove_words = ["play", "song", "gaana", "chalao"]
    for word in remove_words:
        query = query.lower().replace(word, "")
    return query.strip()
Use like:

Python id="ytcleanmain"
elif intent == "youtube":
    clean = clean_query(query)
    play_youtube_song(clean)


🔷 YouTube Music Control Functions

Code :-
import pyautogui
import time

def stop_song():
    pyautogui.press("k")   # YouTube play/pause
    speak("Song band kar diya")

def next_song():
    pyautogui.hotkey("shift", "n")
    speak("Next song play kar raha hu")

def previous_song():
    pyautogui.hotkey("shift", "p")
    speak("Previous song play kar raha hu")

def volume_up():
    pyautogui.press("volumeup")
    speak("Volume badha diya")

def volume_down():
    pyautogui.press("volumedown")
    speak("Volume kam kar diya")

def mute_volume():
    pyautogui.press("volumemute")
    speak("Volume mute kar diya")


🔷 YouTube Background Music Mode

Code :-
music_mode = False

def background_music_on():
    global music_mode
    music_mode = True
    speak("Background music mode on hai")

def background_music_off():
    global music_mode
    music_mode = False
    speak("Background music mode off hai")

🔷 Intent Update (IMPORTANT)

Code :-
def detect_intent(text):
    text = text.lower()

    if "band karo" in text or "stop" in text:
        return "stop"

    elif "next" in text:
        return "next"

    elif "previous" in text or "pichla" in text:
        return "previous"

    elif "volume" in text:
        return "volume"

    elif "background music" in text:
        return "bgmusic"

    elif any(word in text for word in ["play", "song", "gaana", "chalao"]):
        return "youtube"

    return "unknown"