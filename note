🔷 Its reply database will function in a manner similar to what is shown in the code below.

Code :-
replies = {
    "hello": ["Hello! Kaise ho?", "Hi! Main Isha bol rahi hu"],
    "hi": ["Hi! Kya help chahiye?", "Hello!"],
    "thanks": ["Welcome!", "Koi baat nahi 😊"],
    "thank you": ["Welcome!", "Khushi hui help karke"],
    "your name": ["Mera naam Isha hai", "Isha assistant hu main"],
    "who are you": ["Main Isha hu, tumhari assistant"],
}

👉👉 import random

def smart_reply(command):

    command = command.lower()

    for key in replies:
        if key in command:
            response = random.choice(replies[key])
            speak(response)
            return True

    return False


